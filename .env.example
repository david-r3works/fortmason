# Supabase — find these in your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used by server-side operations and Edge Functions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The canonical URL of this app (used for OAuth redirects)
NEXT_PUBLIC_SITE_URL=https://fortmason.info

# Email — Supabase handles transactional email, but you can override SMTP
# in Supabase project Settings > Auth > SMTP
